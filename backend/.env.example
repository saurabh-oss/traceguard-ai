# ── LLM Provider ────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to "groq" (default), "openai", or "anthropic"
LLM_PROVIDER=groq

# Groq (default — free tier works fine)
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (optional, used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk_your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional, used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Observability ────────────────────────────────────────────────────────────
LANGCHAIN_API_KEY=lsv2_your-langsmith-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=traceguard-ai

# ── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_REPO=your-org/your-agent-repo

# ── Database ─────────────────────────────────────────────────────────────────
# Leave as SQLite for local dev; set a PostgreSQL URL for production
DATABASE_URL=sqlite:///./traceguard.db

# ── Server ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
SECRET_KEY=change-me-in-production

# ── Auth ─────────────────────────────────────────────────────────────────────
# Set a strong random value to protect write endpoints (approve/reject/simulate/ingest)
# Leave empty to disable auth (local dev / demo only)
API_KEY=

# ── Notifications ────────────────────────────────────────────────────────────
# Slack incoming webhook URL — TraceGuard posts here when a patch PR is ready
# Leave empty to disable
SLACK_WEBHOOK_URL=
